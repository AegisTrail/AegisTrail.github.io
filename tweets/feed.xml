---
layout: compress
permalink: /tweets/feed.xml
---

{% assign tweets = site.tweets | sort: 'date' | reverse %}
{% capture source %}
<feed xmlns="http://www.w3.org/2005/Atom">
  <id>{{ '/tweets/' | absolute_url }}</id>
  <title>{{ site.title }} / Tweets</title>
  <subtitle>Short-form notes and microblog posts from {{ site.social.name }}</subtitle>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <author>
    <name>{{ site.social.name }}</name>
    <uri>{{ '/tweets/' | absolute_url }}</uri>
  </author>
  <link rel="self" type="application/atom+xml" href="{{ page.url | absolute_url }}"/>
  <link rel="alternate" type="text/html" hreflang="{{ site.alt_lang | default: site.lang }}" href="{{ '/tweets/' | absolute_url }}"/>
  <generator uri="https://jekyllrb.com/" version="{{ jekyll.version }}">Jekyll</generator>

{% for tweet in tweets limit: 20 %}
  {% assign tweet_absolute_url = tweet.url | absolute_url %}
  <entry>
    <title>{{ tweet.title }}</title>
    <link href="{{ tweet_absolute_url }}" rel="alternate" type="text/html" title="{{ tweet.title | xml_escape }}" />
    <published>{{ tweet.date | date_to_xmlschema }}</published>
    <updated>{{ tweet.date | date_to_xmlschema }}</updated>
    <id>{{ tweet_absolute_url }}</id>
    <content type="html">{{ tweet.content | markdownify | xml_escape }}</content>
    <author>
      <name>{{ site.social.name }}</name>
    </author>
    {% for tag in tweet.tags %}
    <category term="{{ tag }}" />
    {% endfor %}
  </entry>
{% endfor %}
</feed>
{% endcapture %}
{{ source | replace: '&', '&amp;' }}
